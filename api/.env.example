# API environment example
# Copy to api/.env for local development. Never commit real secrets.

# PostgreSQL local overrides (optional; Rails also honors DATABASE_URL)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_NAME=household_cfo_api_development
# DATABASE_TEST_NAME=household_cfo_api_test
# Production deploys can set DATABASE_URL only; Solid Cache/Queue default to the same URL.
# DATABASE_URL=postgresql://user:password@host/database
# Optional: use separate databases for Solid Cache/Queue if your host supports them.
# CACHE_DATABASE_URL=postgresql://user:password@host/cache_database
# QUEUE_DATABASE_URL=postgresql://user:password@host/queue_database
# SOLID_QUEUE_IN_PUMA=true

# Clerk auth
# Use either CLERK_JWKS_URL or CLERK_ISSUER. CLERK_SECRET_KEY is only needed
# for backend profile fallback/invitations; it is not required for JWT signature checks.
# CLERK_JWKS_URL=https://your-household-cfo-dev.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://your-household-cfo-dev.clerk.accounts.dev
# CLERK_AUDIENCE=household-cfo-api
# CLERK_SECRET_KEY=sk_test_...
# CLERK_BOOTSTRAP_ADMIN_EMAILS=owner@example.com
# ALLOW_FIRST_USER_BOOTSTRAP=false
# Optional db:seed extras. shimizutechnology@gmail.com is seeded as the default owner admin invite.
# SEED_ADMIN_EMAILS=owner@example.com,partner@example.com

# Frontend CORS allowlist
# The API includes householdcfomethod.com, www.householdcfomethod.com, and
# household-cfo.netlify.app as safe defaults. Localhost defaults are non-production only.
# Add deploy previews or alternate domains here.
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173,https://householdcfomethod.com,https://www.householdcfomethod.com,https://household-cfo.netlify.app

# Email invites via Resend (optional locally; required for real invite email delivery)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="Household CFO <noreply@example.com>"
# MAILER_FROM_EMAIL=noreply@example.com

# Mia / OpenRouter integration (optional for chat fallback; required for document extraction)
# MIA_PERSONA_ID=mia_household_cfo_guam
# OPENROUTER_API_KEY=sk-or-...
# Chat model: OpenRouter currently exposes Sonnet via the latest alias; use exact Sonnet ID when desired.
OPENROUTER_MODEL=~anthropic/claude-sonnet-latest
# Keep extraction on Gemini Flash unless receipt/statement extraction quality requires a stronger model.
OPENROUTER_EXTRACTION_MODEL=google/gemini-2.5-flash
OPENROUTER_PDF_ENGINE=mistral-ocr

# Private financial document storage (required before enabling uploads)
# AWS_REGION=ap-southeast-2
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=household-cfo-private-dev
AWS_S3_PREFIX=household-cfo/development
