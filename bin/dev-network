#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
API_PORT="${API_PORT:-3000}"
WEB_PORT="${WEB_PORT:-5173}"
DEMO_DOCS_DIR="${DEMO_DOCS_DIR:-${HOME}/Desktop/hcfo-demo-uploads}"

find_lan_ip() {
  if [[ -n "${LAN_IP:-}" ]]; then
    printf '%s\n' "${LAN_IP}"
    return
  fi

  local candidate
  for iface in en0 en1 en2; do
    candidate="$(ipconfig getifaddr "${iface}" 2>/dev/null || true)"
    if [[ -n "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return
    fi
  done

  candidate="$(ifconfig | awk '/inet / && $2 !~ /^127\./ { print $2; exit }')"
  if [[ -n "${candidate}" ]]; then
    printf '%s\n' "${candidate}"
    return
  fi

  printf '%s\n' "127.0.0.1"
}

LAN_IP="$(find_lan_ip)"
API_URL="http://${LAN_IP}:${API_PORT}"
WEB_URL="http://${LAN_IP}:${WEB_PORT}"
LOCAL_WEB_URL="http://localhost:${WEB_PORT}"

API_PID=""
WEB_PID=""
cleanup() {
  echo
  echo "Stopping Household CFO local network servers..."
  [[ -n "${WEB_PID}" ]] && kill "${WEB_PID}" 2>/dev/null || true
  [[ -n "${API_PID}" ]] && kill "${API_PID}" 2>/dev/null || true
  wait "${WEB_PID}" 2>/dev/null || true
  wait "${API_PID}" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

cd "${ROOT_DIR}"
DEMO_DIR="$(${ROOT_DIR}/scripts/create-demo-upload-documents "${DEMO_DOCS_DIR}")"

cat <<INFO
Household CFO local network dev

LAN IP:        ${LAN_IP}
Mac URL:       ${LOCAL_WEB_URL}
Phone URL:     ${WEB_URL}
API health:    ${API_URL}/up
Demo uploads:  ${DEMO_DIR}

Requirements for document testing:
- Use signed-in real mode, not demo preview mode.
- CSV/spreadsheet demo uploads work without OpenRouter.
- Receipt/photo/PDF OCR requires api/.env OPENROUTER_API_KEY and private S3 env vars.
- If Clerk rejects the phone URL, add ${WEB_URL} as an allowed dev origin/redirect in Clerk.

Requirements for Plaid Sandbox testing:
- Add PLAID_ENV, PLAID_CLIENT_ID, PLAID_SECRET, and PLAID_DATA_ENCRYPTION_KEY to api/.env.
- Use My Profile in signed-in real mode; Plaid secrets stay server-side.

Press Ctrl+C here to stop both servers.
INFO

(
  cd "${ROOT_DIR}/api"
  bundle check >/dev/null 2>&1 || bundle install
  bin/rails db:prepare
  FRONTEND_URLS="http://localhost:${WEB_PORT},http://127.0.0.1:${WEB_PORT},${WEB_URL}" \
  FRONTEND_URL="${WEB_URL}" \
  bin/rails server -b 0.0.0.0 -p "${API_PORT}"
) &
API_PID=$!

(
  cd "${ROOT_DIR}/web"
  if [[ ! -d node_modules ]]; then
    npm install
  fi
  VITE_API_BASE_URL="${API_URL}" \
  VITE_SITE_URL="${WEB_URL}" \
  npm run dev -- --host 0.0.0.0 --port "${WEB_PORT}"
) &
WEB_PID=$!

while kill -0 "${API_PID}" 2>/dev/null && kill -0 "${WEB_PID}" 2>/dev/null; do
  sleep 1
done
