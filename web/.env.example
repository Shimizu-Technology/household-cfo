# Web environment example
# Copy to web/.env.local for local development. Never commit real secrets.

VITE_API_BASE_URL=http://localhost:3000

# Public site URL used for canonical SEO metadata and generated sitemap/robots files.
# Set this to the Netlify custom domain once DNS is live, e.g. https://your-domain.com
VITE_SITE_URL=http://localhost:5173

# Clerk auth (optional in local dev; required for hosted/cohort environments)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional PostHog analytics/session replay. Analytics stays disabled unless a key is present.
# Production defaults to the same-origin Netlify proxy at /vera-insights.
# Session replay is opt-in and masks all inputs/text by default for financial privacy.
# VITE_PUBLIC_POSTHOG_KEY=phc_...
# VITE_PUBLIC_POSTHOG_HOST=/vera-insights
VITE_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
# VITE_PUBLIC_POSTHOG_SESSION_REPLAY=true
# VITE_ENABLE_ANALYTICS_IN_DEV=true
