# Web environment example
# Copy to web/.env.local for local development. Never commit real secrets.

VITE_API_BASE_URL=http://localhost:3000

# Clerk auth (optional in local dev; required for hosted/cohort environments)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Optional custom JWT template that includes email/email_address claims.
# VITE_CLERK_JWT_TEMPLATE=household-cfo-api
